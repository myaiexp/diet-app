{
  "name": "@diet-app/db",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "generate": "npx tsx ../../node_modules/.bin/drizzle-kit generate",
    "migrate": "npx tsx ../../node_modules/.bin/drizzle-kit migrate",
    "studio": "npx tsx ../../node_modules/.bin/drizzle-kit studio",
    "seed": "tsx src/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "drizzle-orm": "latest",
    "pg": "latest",
    "dotenv": "latest"
  },
  "devDependencies": {
    "drizzle-kit": "latest",
    "@types/pg": "latest",
    "typescript": "latest",
    "tsx": "latest",
    "vitest": "latest"
  }
}
